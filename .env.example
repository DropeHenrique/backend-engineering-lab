# =============================================================================
# Backend Engineering Lab — variáveis raiz (referência para compose)
# Copie para .env na raiz ou use os .env.example de cada serviço.
# =============================================================================

# ----- Infra compartilhada -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# Exchange / filas (deve coincidir entre notification-service e webhook-service)
RABBITMQ_EXCHANGE=lab.events
RABBITMQ_QUEUE_NOTIFICATIONS=notifications
RABBITMQ_QUEUE_DLQ=notifications.dlq

# Portas públicas (host)
NOTIFICATION_HTTP_PORT=8081
WEBHOOK_HTTP_PORT=8082
RATE_LIMITER_HTTP_PORT=3000

# ----- notification-service -----
NOTIFICATION_APP_KEY=base64:CHANGE_ME_IN_NOTIFICATION_SERVICE_ENV

# ----- webhook-service -----
WEBHOOK_APP_KEY=base64:CHANGE_ME_IN_WEBHOOK_SERVICE_ENV
WEBHOOK_STRIPE_SECRET=stripe_hmac_lab_secret_plain
WEBHOOK_GITHUB_SECRET=demo_github_webhook_secret
WEBHOOK_HOTMART_SECRET=demo_hotmart_hmac_secret
WEBHOOK_GENERIC_SECRET=demo_generic_secret

# ----- rate-limiter -----
REDIS_DOWN_MODE=allow
RATE_LIMIT_DEFAULT_PLAN=free
