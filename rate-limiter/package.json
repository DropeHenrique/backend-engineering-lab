{
  "name": "rate-limiter",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "dependencies": {
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.4.2",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint src",
    "format": "prettier --write src __tests__",
    "format:check": "prettier --check src __tests__",
    "test": "jest --coverage --runInBand --forceExit",
    "test:integration": "REDIS_URL=redis://127.0.0.1:6379 jest __tests__/rateLimiter.redis.integration.test.js --runInBand --forceExit",
    "load:k6": "k6 run load-test/smoke.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
